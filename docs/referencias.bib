@article{vannoortSpatiallyCoupledInversion2012,
  title = {Spatially Coupled Inversion of Spectro-Polarimetric Image Data: {{I}}. {{Method}} and First Results},
  shorttitle = {Spatially Coupled Inversion of Spectro-Polarimetric Image Data},
  author = {Van Noort, M.},
  date = {2012-12},
  journaltitle = {Astronomy \& Astrophysics},
  shortjournal = {A\&A},
  volume = {548},
  pages = {A5},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/201220220},
  url = {http://www.aanda.org/10.1051/0004-6361/201220220},
  urldate = {2026-05-19},
  abstract = {Methods. By accounting for the diffraction PSF of the telescope during the inversions, we can produce a self-consistent solution that best fits the observed data, while simultaneously requiring fewer free parameters than conventional approaches. Results. Simulations using realistic MHD data indicate that the method is stable for all resolutions, including those with pixel scales well beyond those that can be resolved with a 0.5 m telescope, such as the Hinode SOT. Application of the presented method to reduce full Stokes data from the Hinode spectro-polarimeter results in dramatically increased image contrast and an increase in the resolution of the data to the diffraction limit of the telescope in almost all Stokes and fit parameters. The resulting data allow for detecting and interpreting solar features that have so far only been observed with 1m class ground-based telescopes. Conclusions. A new inversion method was developed that allows for accurate fitting of solar spectro-polarimetric imaging data over a large field of view, while simultaneously improving the noise statistics and spatial resolution of the results significantly.},
  langid = {english},
  file = {/home/pabloore/Zotero/storage/3HVIT42Y/Van Noort - 2012 - Spatially coupled inversion of spectro-polarimetric image data I. Method and first results.pdf}
}
